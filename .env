# API
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL (job state + validation payloads)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/snowflake_loader

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0
# Set true to run import tasks in-process (no Redis/worker) — handy for local API-only dev
CELERY_TASK_ALWAYS_EAGER=true

# Upload storage (relative to cwd or absolute)
UPLOAD_DIR=./data/uploads

# Validation
IMPORT_MAX_ROWS=500000
IMPORT_MAX_FILE_MB=50
# Optional comma-separated logical names after normalization (e.g. id,amount,date)
REQUIRED_COLUMNS=

# Snowflake (use a dedicated loader user + least privilege)
SNOWFLAKE_ACCOUNT=xy12345.eu-west-1
SNOWFLAKE_USER=LOADER_USER
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=LOADER_ROLE
SNOWFLAKE_WAREHOUSE=LOAD_WH
SNOWFLAKE_DATABASE=LOAD_DB
SNOWFLAKE_SCHEMA=LOAD_SCHEMA
# Target table for write_pandas (created if missing when AUTO_CREATE_SNOWFLAKE_TABLE=true)
SNOWFLAKE_TABLE=EXCEL_IMPORTS_RAW
AUTO_CREATE_SNOWFLAKE_TABLE=true
